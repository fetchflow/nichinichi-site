---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base
  title="CLI Tutorial — Nichinichi"
  description="Step-by-step guide to using the nichinichi CLI to log entries, track goals, run playbooks, and query your journal with AI."
>
  <Nav />
  <main class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
          <a href={base} class="hover:text-white transition-colors">Home</a>
          <span>/</span>
          <a href={`${base}docs`} class="hover:text-white transition-colors">Docs</a>
          <span>/</span>
          <span class="text-gray-300">CLI Tutorial</span>
        </div>
        <h1 class="text-4xl font-bold text-white mb-4">CLI Tutorial</h1>
        <p class="text-lg text-gray-400">
          The nichinichi CLI is the fastest way to capture thoughts, log decisions, and query your history — without leaving the terminal.
        </p>
      </div>

      <!-- Table of Contents -->
      <nav class="mb-12 p-5 rounded-xl bg-gray-900 border border-gray-800">
        <p class="text-xs font-mono text-gray-500 uppercase tracking-wider mb-3">On this page</p>
        <ol class="space-y-1.5 text-sm">
          <li><a href="#install" class="text-gray-400 hover:text-white transition-colors">1. Installation</a></li>
          <li><a href="#first-entry" class="text-gray-400 hover:text-white transition-colors">2. Your first entry</a></li>
          <li><a href="#entry-types" class="text-gray-400 hover:text-white transition-colors">3. Entry types</a></li>
          <li><a href="#orgs" class="text-gray-400 hover:text-white transition-colors">4. Orgs &amp; workspaces</a></li>
          <li><a href="#goals" class="text-gray-400 hover:text-white transition-colors">5. Goal tracking</a></li>
          <li><a href="#playbooks" class="text-gray-400 hover:text-white transition-colors">6. Playbooks</a></li>
          <li><a href="#ask" class="text-gray-400 hover:text-white transition-colors">7. AI ask</a></li>
          <li><a href="#sync" class="text-gray-400 hover:text-white transition-colors">8. Sync &amp; archive</a></li>
        </ol>
      </nav>

      <!-- 1. Installation -->
      <section id="install" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">1. Installation</h2>
        <p class="text-gray-400 mb-4">Pick the install method that fits your setup. All options give you both the CLI and desktop app.</p>

        <div class="space-y-4">
          <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden">
            <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800 flex items-center gap-2">
              <span class="text-xs text-gray-500 font-mono">macOS — Homebrew (recommended)</span>
            </div>
            <div class="p-4 font-mono text-sm">
              <div class="flex items-start gap-2">
                <span class="text-green-400 mt-0.5">$</span>
                <span class="text-gray-200">brew install fetchflow/tap/nichinichi</span>
              </div>
            </div>
          </div>

          <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden">
            <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800 flex items-center gap-2">
              <span class="text-xs text-gray-500 font-mono">Cargo (any platform with Rust toolchain)</span>
            </div>
            <div class="p-4 font-mono text-sm">
              <div class="flex items-start gap-2">
                <span class="text-green-400 mt-0.5">$</span>
                <span class="text-gray-200">cargo install nichinichi-cli</span>
              </div>
            </div>
          </div>

          <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden">
            <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800 flex items-center gap-2">
              <span class="text-xs text-gray-500 font-mono">Linux — binary download</span>
            </div>
            <div class="p-4 font-mono text-sm">
              <a
                href="https://github.com/fetchflow/nichinichi/releases/latest"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm border border-gray-700 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Download from GitHub Releases
              </a>
            </div>
          </div>
        </div>

        <div class="mt-4 p-4 rounded-xl bg-blue-950/30 border border-blue-800/40 text-sm text-blue-300">
          Verify the install: <code class="font-mono bg-blue-900/30 px-1.5 py-0.5 rounded text-blue-200">nichinichi --version</code>
        </div>
      </section>

      <!-- 2. First entry -->
      <section id="first-entry" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">2. Your first entry</h2>
        <p class="text-gray-400 mb-4">
          Your first entry initializes <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded text-sm">~/nichinichi/</code> and writes a markdown file. Nothing else happens — no signup, no cloud.
        </p>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden mb-4">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-3">
            <div>
              <span class="text-gray-500"># Shorthand: quote is the entire log command</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi "stood up the auth service #solution @backend"</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Explicit log subcommand (same result)</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi log "stood up the auth service #solution @backend"</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3 text-gray-500">
              <div>→ Writes to ~/nichinichi/2026-03-25.md</div>
              <div class="mt-1">→ Appends: <span class="text-gray-400">09:14 stood up the auth service #solution @backend</span></div>
            </div>
          </div>
        </div>

        <p class="text-gray-400 text-sm mb-4">
          After logging, build the SQLite index so queries and the desktop app can read your entries:
        </p>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm">
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi sync --rebuild</span>
            </div>
            <div class="mt-2 text-gray-500">→ Drops and reconstructs the SQLite index from your markdown files.</div>
          </div>
        </div>

        <div class="mt-4 p-4 rounded-xl bg-gray-900/40 border border-gray-800 text-sm text-gray-400">
          <strong class="text-white">File layout:</strong> nichinichi writes one markdown file per day: <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">~/nichinichi/YYYY-MM-DD.md</code>. Each line is a timestamped entry. SQLite is just a query cache — delete it and <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">sync --rebuild</code> restores everything.
        </div>
      </section>

      <!-- 3. Entry types -->
      <section id="entry-types" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">3. Entry types</h2>
        <p class="text-gray-400 mb-6">
          Tag entries with <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded text-sm">#type</code> to categorize your history. If you omit the type, nichinichi infers it from keywords in your text.
        </p>

        <div class="space-y-2 mb-8">
          {[
            { type: 'log', color: 'type-log', keywords: '(default)', desc: 'General notes, observations, status updates.' },
            { type: 'solution', color: 'type-solution', keywords: '"fixed", "resolved", "debugged"', desc: 'Things you figured out — bugs, blockers, how-tos.' },
            { type: 'decision', color: 'type-decision', keywords: '"chose", "decided", "going with"', desc: 'Architectural or product decisions and their rationale.' },
            { type: 'reflection', color: 'type-reflection', keywords: '"realized", "noticed", "learned"', desc: 'Retrospectives, lessons, personal observations.' },
            { type: 'score', color: 'type-score', keywords: '"shipped", "merged", "deployed", "released"', desc: 'Wins, milestones, things you shipped.' },
            { type: 'ai', color: 'type-ai', keywords: '"asked ai", "claude", "gpt"', desc: 'AI-assisted work or prompts worth remembering.' },
          ].map(({ type, color, keywords, desc }) => (
            <div class="flex gap-4 p-4 rounded-lg bg-gray-900 border border-gray-800">
              <span class={`shrink-0 px-2 py-0.5 rounded text-xs font-mono border ${color}`}>#{type}</span>
              <div class="min-w-0">
                <p class="text-gray-200 text-sm">{desc}</p>
                <p class="text-gray-500 text-xs mt-1 font-mono">inferred from: {keywords}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Examples</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-2">
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi "fixed the N+1 query in user listings"</span>
              <span class="text-gray-600 ml-auto shrink-0">→ #solution</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi "chose Postgres over MySQL for jsonb support"</span>
              <span class="text-gray-600 ml-auto shrink-0">→ #decision</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi "shipped v1.2 to prod #score @backend"</span>
              <span class="text-gray-600 ml-auto shrink-0">→ #score</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi "standup: auth done, rate limiting next #log"</span>
              <span class="text-gray-600 ml-auto shrink-0">→ #log</span>
            </div>
          </div>
        </div>
      </section>

      <!-- 4. Orgs -->
      <section id="orgs" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">4. Orgs &amp; workspaces</h2>
        <p class="text-gray-400 mb-4">
          Use <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded text-sm">@org</code> to tag entries with a project or context. This lets you filter your journal — in the AI panel, in goals, in playbooks — to a specific workspace.
        </p>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden mb-4">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-2">
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi "migrated to Neon serverless #solution @dayflow"</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi "planning sprint 4 @kiban #log"</span>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green-400">$</span>
              <span class="text-gray-200">nichinichi ask "what did I do on the auth service?" --org dayflow</span>
            </div>
          </div>
        </div>

        <p class="text-gray-400 text-sm">
          If you log without an <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">@org</code> tag in a terminal, nichinichi will prompt you to pick one (or use <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">default_org</code> from <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">~/.nichinichi.yml</code>).
        </p>
      </section>

      <!-- 5. Goals -->
      <section id="goals" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">5. Goal tracking</h2>
        <p class="text-gray-400 mb-4">
          Goals are stored as markdown files in <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded text-sm">~/nichinichi/goals/active/</code>. Each goal has a title, optional steps, and a progress signal derived from related log entries.
        </p>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden mb-4">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-4">
            <div>
              <span class="text-gray-500"># List active goals</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi goals list</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Create a new goal (interactive prompts follow)</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi goals add "Ship billing integration" --type career</span>
              </div>
              <div class="mt-2 text-gray-500 pl-6">
                <div>? Why is this goal important? Unblocks paid tier launch</div>
                <div>? Horizon (e.g. Q2 2026)? Q2 2026</div>
                <div>? Org? dayflow</div>
                <div>? Add steps (blank to finish):</div>
                <div>  → Integrate Stripe checkout</div>
                <div>  → Add webhook handler</div>
                <div>  → (blank)</div>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Archive a completed goal</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi goals done "ship-billing-integration"</span>
              </div>
              <div class="mt-1 text-gray-500 pl-6">→ Moves to ~/nichinichi/goals/archive/, sets status: done</div>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-xl bg-gray-900/40 border border-gray-800 text-sm text-gray-400">
          Goals surface in the desktop app's Goals view with a visual progress signal: <span class="text-green-400">breakthrough</span>, <span class="text-blue-400">strong</span>, <span class="text-gray-300">steady</span>, <span class="text-yellow-400">moderate</span>, <span class="text-orange-400">struggling</span>, <span class="text-gray-500">quiet</span>.
        </div>
      </section>

      <!-- 6. Playbooks -->
      <section id="playbooks" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">6. Playbooks</h2>
        <p class="text-gray-400 mb-4">
          Playbooks are reusable runbooks — deployment checklists, incident templates, onboarding guides. They live in <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded text-sm">~/nichinichi/playbooks/</code> as markdown.
        </p>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-3">
            <div>
              <span class="text-gray-500"># Create a new playbook (opens in your $EDITOR)</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi playbooks add "Deploy to production"</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># List all playbooks</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi playbooks list</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 7. AI ask -->
      <section id="ask" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">7. AI ask</h2>
        <p class="text-gray-400 mb-4">
          Query your journal with natural language. nichinichi searches your entries with full-text search, then streams an AI-generated response based on the results.
        </p>

        <div class="mb-4 p-4 rounded-xl bg-amber-950/30 border border-amber-800/40 text-sm text-amber-300">
          <strong class="text-amber-200">Prerequisite:</strong> Configure an AI provider in <code class="font-mono bg-amber-900/30 px-1.5 py-0.5 rounded">~/.nichinichi.yml</code> — Ollama (local), Open WebUI, or any OpenAI-compatible endpoint.
        </div>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden mb-4">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-3">
            <div>
              <span class="text-gray-500"># Ask across your entire journal</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi ask "when did I fix the race condition in the queue?"</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Scope the query to a specific org</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi ask "what decisions did I make this month?" --org dayflow</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Save the response to ~/nichinichi/ai/</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi ask "summarize my work this week" --save</span>
              </div>
            </div>
          </div>
        </div>

        <p class="text-gray-400 text-sm">
          Responses stream to stdout in real time. Use <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">--save</code> to persist the conversation for later retrieval in the desktop AI panel.
        </p>
      </section>

      <!-- 8. Sync & archive -->
      <section id="sync" class="mb-16 scroll-mt-20">
        <h2 class="text-2xl font-bold text-white mb-6">8. Sync &amp; archive</h2>
        <p class="text-gray-400 mb-4">
          The SQLite database is a derived artifact — your markdown files are always the source of truth. Sync keeps them in alignment.
        </p>

        <div class="rounded-xl bg-gray-900 border border-gray-800 overflow-hidden mb-4">
          <div class="px-4 py-2.5 bg-gray-800/40 border-b border-gray-800">
            <span class="text-xs text-gray-500 font-mono">Terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-3">
            <div>
              <span class="text-gray-500"># Incremental sync (new/changed files only)</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi sync</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Full rebuild (after editing markdown by hand)</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi sync --rebuild</span>
              </div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Archive all entries from 2025 into archive/2025/</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi archive --year 2025</span>
              </div>
              <div class="mt-1 text-gray-500 pl-6">→ Moves YYYY-MM-DD.md files to ~/nichinichi/archive/2025/ (prompts to confirm)</div>
            </div>
            <div class="border-t border-gray-800 pt-3">
              <span class="text-gray-500"># Skip confirmation prompt</span>
              <div class="mt-1 flex items-start gap-2">
                <span class="text-green-400">$</span>
                <span class="text-gray-200">nichinichi archive --year 2025 -y</span>
              </div>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-xl bg-gray-900/40 border border-gray-800 text-sm text-gray-400">
          <strong class="text-white">Tip:</strong> Back up your journal by committing <code class="font-mono text-gray-300 bg-gray-800 px-1.5 py-0.5 rounded">~/nichinichi/</code> to a private git repo. The desktop app watches for file changes and re-syncs automatically.
        </div>
      </section>

      <!-- Next steps -->
      <section class="border-t border-gray-800 pt-12">
        <h2 class="text-xl font-bold text-white mb-4">Next steps</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href={`${base}docs/desktop`} class="group p-5 rounded-xl bg-gray-900 border border-gray-800 hover:border-gray-600 transition-colors">
            <p class="font-semibold text-white mb-1 group-hover:text-green-400 transition-colors">Desktop app tutorial →</p>
            <p class="text-sm text-gray-400">Dashboard, goals view, AI panel, and settings.</p>
          </a>
          <a href="https://github.com/fetchflow/nichinichi" target="_blank" rel="noopener noreferrer" class="group p-5 rounded-xl bg-gray-900 border border-gray-800 hover:border-gray-600 transition-colors">
            <p class="font-semibold text-white mb-1 group-hover:text-green-400 transition-colors">GitHub →</p>
            <p class="text-sm text-gray-400">Source code, issues, and releases.</p>
          </a>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Base>
