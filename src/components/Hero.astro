---
---

<section class="relative pt-28 pb-20 px-6 overflow-hidden">
  <!-- Background grid -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 48px 48px;"
  ></div>

  <!-- Ambient glow -->
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full bg-green-500/5 blur-3xl pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-800/80 border border-gray-700/60 text-sm text-gray-400 mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
      Open source · Local-first · No account required
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-[1.1]">
      Your dev brain,<br />
      <span class="text-gradient">on disk.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      A local-first journal for developers. Log decisions, track goals, and ask AI
      about your own work — no account, no cloud, no lock-in. Your data stays in
      plain markdown files on your machine.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-16">
      <a
        href="#install"
        class="glow-green inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-green-500 hover:bg-green-400 text-black font-semibold text-sm transition-all"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download
      </a>
      <a
        href="https://github.com/fetchflow/nichinichi"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-200 font-semibold text-sm border border-gray-700 hover:border-gray-600 transition-all"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Terminal demo -->
    <div class="max-w-2xl mx-auto rounded-xl bg-gray-900 border border-gray-800 overflow-hidden text-left shadow-2xl mb-12">
      <!-- Terminal chrome -->
      <div class="flex items-center gap-2 px-4 py-3 bg-gray-800/50 border-b border-gray-800">
        <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
        <span class="ml-3 text-xs text-gray-500 font-mono">~/projects/api-refactor</span>
      </div>
      <!-- Terminal body -->
      <div class="p-4 font-mono text-sm leading-7 text-gray-300">
        <div>
          <span class="text-green-400">$</span>
          <span class="ml-2">nichinichi <span class="text-yellow-300">"fixed jwt refresh swallowing errors @acme #solution"</span></span>
        </div>
        <div class="text-gray-500">  → logged to 2026-03-22.md</div>
        <div class="mt-1">
          <span class="text-green-400">$</span>
          <span class="ml-2">nichinichi ask <span class="text-yellow-300">"when did I last fix an auth bug"</span></span>
        </div>
        <div class="text-gray-400 mt-1">
          <span class="text-blue-400">nichinichi:</span>
          You fixed a JWT refresh bug on 2026-03-22 at @acme.<br />
          &nbsp;&nbsp;Root cause: expiry check after decode, not before.<br />
          &nbsp;&nbsp;Time lost: 2hrs. You noted "check expiry BEFORE decode, always."
        </div>
        <div class="mt-1 flex items-center gap-1">
          <span class="text-green-400">$</span>
          <span class="ml-2 w-2 h-4 bg-green-400 animate-pulse inline-block"></span>
        </div>
      </div>
    </div>

    <!-- App screenshot -->
    <div class="max-w-5xl mx-auto rounded-2xl overflow-hidden border border-gray-700/60 shadow-[0_0_80px_rgba(0,0,0,0.6)] ring-1 ring-white/5">
      <img
        src="/screenshots/dashboard.png"
        alt="Nichinichi dashboard showing heatmap, entry type breakdown, and goal progress"
        class="w-full block"
        width="1280"
        height="800"
        loading="eager"
      />
    </div>
  </div>
</section>
