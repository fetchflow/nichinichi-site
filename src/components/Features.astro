---
const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/>`,
    title: 'Local-first',
    description: 'All data lives as plain markdown files on your machine. SQLite is a reconstructable query index — never the source of truth. Git is your backup and sync mechanism.',
    accent: '#22c55e',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
    title: 'CLI + Desktop',
    description: 'Log from the terminal in seconds: `nichinichi "text"`. Open the desktop app to review your dashboard, heatmap, and graphs. Same Rust core, two interfaces.',
    accent: '#3b82f6',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
    title: 'AI over your own history',
    description: 'Ask questions like "when did I fix the auth bug?" or "what decisions did I make last week?" AI searches your SQLite FTS5 index and answers with full context.',
    accent: '#f59e0b',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
    title: 'Goal tracking',
    description: 'Track career and learning goals with signal-based progress: breakthrough, strong, steady, moderate, struggling, or quiet. Steps link back to specific log entries.',
    accent: '#a855f7',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
    title: 'Playbooks',
    description: 'Store repeatable runbooks as markdown files. Search them with FTS5. Fork from a colleague\'s playbook. They live alongside your entries — always in context.',
    accent: '#ec4899',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>`,
    title: '.quiet/ privacy',
    description: 'Drop files in .quiet/ and they are never indexed, never synced, never sent to AI — enforced in the file watcher and rebuild, not just the UI. No exceptions.',
    accent: '#6b7280',
  },
];
---

<section id="features" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Everything you need,<br />nothing you don't</h2>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">Built for developers who want to own their data and think clearly over time.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f) => (
        <div class="group p-6 rounded-xl bg-gray-900/60 border border-gray-800 hover:border-gray-700 transition-all hover:bg-gray-900">
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center mb-4"
            style={`background: ${f.accent}18; border: 1px solid ${f.accent}30;`}
          >
            <svg class="w-5 h-5" fill="none" stroke={f.accent} viewBox="0 0 24 24" set:html={f.icon} />
          </div>
          <h3 class="font-semibold text-white mb-2">{f.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
