---
const base = import.meta.env.BASE_URL;
const steps = [
  {
    number: '01',
    title: 'Log',
    description: 'One command to capture what you\'re doing — decision, fix, score, or just a note. Type-tag it, org-tag it, move on. Takes under 5 seconds.',
    screenshot: `${base}screenshots/log-feed.png`,
    alt: 'Log feed view showing the entry composer and recent entries with type badges',
    color: '#22c55e',
  },
  {
    number: '02',
    title: 'Review',
    description: 'Open the desktop app at any time. Dashboard shows a GitHub-style heatmap, type breakdown, goal progress, and today\'s full log. No setup, no sync.',
    screenshot: `${base}screenshots/dashboard.png`,
    alt: 'Dashboard view showing heatmap, entry type breakdown, and goal progress',
    color: '#3b82f6',
  },
  {
    number: '03',
    title: 'Ask',
    description: 'Open the AI panel and ask anything about your history. Context is built from your own entries via FTS5 full-text search. Your API key, your data.',
    screenshot: `${base}screenshots/ai-panel.png`,
    alt: 'AI panel showing a question and streaming answer sourced from entry history',
    color: '#f59e0b',
  },
];
---

<section id="how-it-works" class="py-24 px-6 border-t border-gray-800/60">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">How it works</h2>
      <p class="text-gray-400 text-lg">Three steps. All local. No friction.</p>
    </div>

    <div class="space-y-12">
      {steps.map((step, i) => (
        <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 items-center`}>
          <!-- Text -->
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-sm font-bold" style={`color: ${step.color}`}>{step.number}</span>
              <h3 class="text-2xl font-bold text-white">{step.title}</h3>
            </div>
            <p class="text-gray-400 leading-relaxed text-lg">{step.description}</p>
          </div>

          <!-- Screenshot -->
          <div class="flex-1 w-full">
            <div class="rounded-xl overflow-hidden border border-gray-700/60 shadow-xl ring-1 ring-white/5">
              <img
                src={step.screenshot}
                alt={step.alt}
                class="w-full block"
                width="900"
                height="560"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
